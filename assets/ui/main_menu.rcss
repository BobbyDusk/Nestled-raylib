body {
    font-family: Quicksand;
    font-size: 18dp;
    color: #333;
    width: 100%;
    height: 100%;
    cursor: default;
}

#menu {
    position: absolute;
    right: 0;
    top: 0;
    bottom: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 400dp;
    padding: 3em;
    background: #ffffffcc;
    border: 2dp #999;
}

h1 {
    color: #c0392b;
    font-size: 2em;
    font-weight: bold;
    margin-bottom: 0.8em;
    text-align: center;
}

button {
    display: block;
    width: 200dp;
    height: 53dp;
    line-height: 53dp;
    text-align: center;
    font-size: 1em;
    border: 0;
}

button:hover {
    cursor: pointer;
    transform: scale(1.05);
}

button:active {
    transform: scale(1.05);
}

.text-button {
    decorator: image(../images/text_button contain);
}
